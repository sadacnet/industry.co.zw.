# Security Headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "DENY"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Content-Security-Policy "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net"
</IfModule>

# Prevent directory listing
Options -Indexes

# Block access to sensitive files
<FilesMatch "\.(env|json|lock|md|sql|log)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Block access to config
<FilesMatch "config\.php$">
    Order Allow,Deny
    Deny from all
</FilesMatch>
# Enable URL rewriting
RewriteEngine On

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "DENY"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Prevent directory listing
Options -Indexes

# Block access to sensitive files
<FilesMatch "\.(htaccess|htpasswd|ini|log|sh|sql)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Block access to includes folder
RewriteRule ^includes/ - [F,L]

# Block access to config files
RewriteRule ^api/config/ - [F,L]

# PHP settings
<IfModule mod_php.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 10M
    php_value max_execution_time 30
</IfModule>